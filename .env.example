# Pusat Arsip Anka - Environment Configuration Template
# Copy this file to backend/.env and fill with your actual values

# ============================================
# Hugging Face Spaces Configuration
# ============================================
PORT=7860
NODE_ENV=production

# ============================================
# Supabase Database Configuration
# ============================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Authentication
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_min_32_characters_long_here
JWT_EXPIRES_IN=24h

# ============================================
# Notifications (Optional)
# ============================================
# Fonnte WhatsApp API (optional for notifications)
FONNTE_TOKEN=your-fonnte-api-token-here

# ============================================
# Storage Configuration (Optional)
# ============================================
# If using rclone for file storage
RCLONE_CONFIG_PATH=./rclone.conf
STORAGE_BACKEND=terabox

# ============================================
# Alist Configuration (Optional)
# ============================================
# Enable or disable Alist service
ENABLE_ALIST=true
ALIST_PORT=5244
ALIST_DATA_PATH=/app/data

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_PATH=/app/data/log

# ============================================
# CORS Settings
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=*

# ============================================
# File Upload Limits
# ============================================
MAX_FILE_SIZE=104857600  # 100MB in bytes
UPLOAD_TEMP_PATH=/app/backend/tmp
