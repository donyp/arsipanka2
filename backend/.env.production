# Pusat Arsip Anka - Production Environment Configuration
# Used automatically when deployed to Hugging Face Spaces

# Server Configuration
PORT=7860
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=512

# These MUST be set in HF Space Settings (Variables and Secrets)
# They are placeholders here for reference
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}
JWT_SECRET=${JWT_SECRET}

# Optional Configurations
FONNTE_TOKEN=${FONNTE_TOKEN}
LOG_LEVEL=info
