# Git attributes for consistent handling

# Auto line endings
* text=auto

# Shell scripts
*.sh eol=lf
start.sh eol=lf
deploy.sh eol=lf

# Batch files
*.bat eol=crlf
deploy.bat eol=crlf

# Documentation
*.md text
*.txt text
*.json text

# Frontend
*.html text
*.js text
*.css text

# Binary files
*.db binary
*.pdf binary
*.exe binary
*.gz binary
*.tar binary
*.zip binary
